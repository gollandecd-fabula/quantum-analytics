{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantum.local/schemas/safe-expression.schema.json",
  "title": "Quantum Safe Financial Expression",
  "$ref": "#/$defs/expression",
  "$defs": {
    "decimalString": {
      "type": "string",
      "pattern": "^-?(0|[1-9][0-9]*)(\\.[0-9]+)?$"
    },
    "integerString": {
      "type": "string",
      "pattern": "^-?(0|[1-9][0-9]*)$"
    },
    "valueType": {
      "type": "string",
      "enum": ["MONEY", "DECIMAL", "RATE", "INTEGER", "BOOLEAN"]
    },
    "literal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value", "value_type", "currency", "unit"],
      "properties": {
        "kind": {"const": "LITERAL"},
        "value": {
          "oneOf": [
            {"$ref": "#/$defs/decimalString"},
            {"type": "boolean"}
          ]
        },
        "value_type": {"$ref": "#/$defs/valueType"},
        "currency": {"type": ["string", "null"], "pattern": "^[A-Z]{3}$"},
        "unit": {"type": ["string", "null"], "minLength": 1}
      },
      "allOf": [
        {
          "if": {
            "properties": {"value_type": {"enum": ["MONEY", "DECIMAL", "RATE"]}},
            "required": ["value_type"]
          },
          "then": {"properties": {"value": {"$ref": "#/$defs/decimalString"}}}
        },
        {
          "if": {
            "properties": {"value_type": {"const": "INTEGER"}},
            "required": ["value_type"]
          },
          "then": {"properties": {"value": {"$ref": "#/$defs/integerString"}}}
        },
        {
          "if": {
            "properties": {"value_type": {"const": "BOOLEAN"}},
            "required": ["value_type"]
          },
          "then": {"properties": {"value": {"type": "boolean"}}}
        },
        {
          "if": {
            "properties": {"value_type": {"const": "MONEY"}},
            "required": ["value_type"]
          },
          "then": {"properties": {"currency": {"type": "string"}}},
          "else": {"properties": {"currency": {"type": "null"}}}
        }
      ]
    },
    "variable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name", "value_type", "currency", "unit"],
      "properties": {
        "kind": {"const": "VARIABLE"},
        "name": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]{0,127}$"},
        "value_type": {"$ref": "#/$defs/valueType"},
        "currency": {"type": ["string", "null"], "pattern": "^[A-Z]{3}$"},
        "unit": {"type": ["string", "null"], "minLength": 1}
      },
      "allOf": [
        {
          "if": {
            "properties": {"value_type": {"const": "MONEY"}},
            "required": ["value_type"]
          },
          "then": {"properties": {"currency": {"type": "string"}}},
          "else": {"properties": {"currency": {"type": "null"}}}
        }
      ]
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "operator", "value_type", "currency", "unit", "arguments"],
      "properties": {
        "kind": {"const": "OPERATION"},
        "operator": {
          "type": "string",
          "enum": [
            "ADD", "SUBTRACT", "MULTIPLY", "DIVIDE", "NEGATE", "ABS",
            "MIN", "MAX", "IF", "EQUAL", "LESS_THAN", "LESS_OR_EQUAL",
            "GREATER_THAN", "GREATER_OR_EQUAL"
          ]
        },
        "value_type": {"$ref": "#/$defs/valueType"},
        "currency": {"type": ["string", "null"], "pattern": "^[A-Z]{3}$"},
        "unit": {"type": ["string", "null"], "minLength": 1},
        "arguments": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {"$ref": "#/$defs/expression"}
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"operator": {"enum": ["NEGATE", "ABS"]}},
            "required": ["operator"]
          },
          "then": {"properties": {"arguments": {"minItems": 1, "maxItems": 1}}}
        },
        {
          "if": {
            "properties": {
              "operator": {
                "enum": [
                  "SUBTRACT", "MULTIPLY", "DIVIDE", "EQUAL", "LESS_THAN",
                  "LESS_OR_EQUAL", "GREATER_THAN", "GREATER_OR_EQUAL"
                ]
              }
            },
            "required": ["operator"]
          },
          "then": {"properties": {"arguments": {"minItems": 2, "maxItems": 2}}}
        },
        {
          "if": {"properties": {"operator": {"const": "IF"}}, "required": ["operator"]},
          "then": {"properties": {"arguments": {"minItems": 3, "maxItems": 3}}}
        },
        {
          "if": {
            "properties": {"operator": {"enum": ["ADD", "MIN", "MAX"]}},
            "required": ["operator"]
          },
          "then": {"properties": {"arguments": {"minItems": 2, "maxItems": 16}}}
        },
        {
          "if": {
            "properties": {
              "operator": {
                "enum": ["EQUAL", "LESS_THAN", "LESS_OR_EQUAL", "GREATER_THAN", "GREATER_OR_EQUAL"]
              }
            },
            "required": ["operator"]
          },
          "then": {
            "properties": {
              "value_type": {"const": "BOOLEAN"},
              "currency": {"type": "null"},
              "unit": {"const": "BOOLEAN"}
            }
          }
        },
        {
          "if": {
            "properties": {"value_type": {"const": "MONEY"}},
            "required": ["value_type"]
          },
          "then": {"properties": {"currency": {"type": "string"}}},
          "else": {"properties": {"currency": {"type": "null"}}}
        }
      ]
    },
    "expression": {
      "oneOf": [
        {"$ref": "#/$defs/literal"},
        {"$ref": "#/$defs/variable"},
        {"$ref": "#/$defs/operation"}
      ]
    }
  }
}
