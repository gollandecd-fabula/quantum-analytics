{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantum.local/schemas/report-export-bundle.schema.json",
  "title": "Quantum Report Export Bundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "organization_id",
    "mode",
    "scenario_id",
    "generated_at",
    "record_count",
    "records",
    "bundle_hash"
  ],
  "properties": {
    "schema_version": {"const": "quantum-report-export-v1"},
    "bundle_id": {"type": "string", "minLength": 1},
    "organization_id": {"type": "string", "minLength": 1},
    "mode": {"enum": ["ACTUAL", "SCENARIO"]},
    "scenario_id": {"type": ["string", "null"], "minLength": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "record_count": {"type": "integer", "minimum": 1, "maximum": 10000},
    "records": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000,
      "items": {"$ref": "report-record.schema.json"}
    },
    "bundle_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "allOf": [
    {
      "if": {"properties": {"mode": {"const": "ACTUAL"}}},
      "then": {"properties": {"scenario_id": {"type": "null"}}}
    },
    {
      "if": {"properties": {"mode": {"const": "SCENARIO"}}},
      "then": {"properties": {"scenario_id": {"type": "string", "minLength": 1}}}
    }
  ]
}
