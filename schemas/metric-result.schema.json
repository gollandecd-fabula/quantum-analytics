{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://quantum.local/schemas/metric-result.schema.json","title":"Quantum Immutable Metric Result Snapshot v1","type":"object","additionalProperties":false,"required":["result_id","result_contract_version","evidence_contract_version","organization_id","marketplace_account_id","mode","scenario_id","calculation_instant","scope_dimensions","calculation_profile_ref","metric_definition_ref","value","evidence_chain","audit","reproduction_hash","content_hash"],"properties":{"result_id":{"type":"string","pattern":"^mr_[a-f0-9]{64}$"},"result_contract_version":{"const":"METRIC-RESULT-v1"},"evidence_contract_version":{"const":"EVIDENCE-CHAIN-v1"},"organization_id":{"type":"string","minLength":1},"marketplace_account_id":{"type":["string","null"],"minLength":1},"mode":{"type":"string","enum":["ACTUAL","SCENARIO"]},"scenario_id":{"type":["string","null"],"minLength":1},"calculation_instant":{"type":"string","format":"date-time"},"scope_dimensions":{"type":"object","propertyNames":{"minLength":1},"additionalProperties":{"type":"string","minLength":1}},"calculation_profile_ref":{"$ref":"https://quantum.local/schemas/metric-result-common.schema.json#/$defs/versionedRef"},"metric_definition_ref":{"$ref":"https://quantum.local/schemas/metric-result-common.schema.json#/$defs/versionedRef"},"value":{"$ref":"https://quantum.local/schemas/metric-result-common.schema.json#/$defs/typedValue"},"evidence_chain":{"$ref":"https://quantum.local/schemas/metric-result-evidence.schema.json#/$defs/evidenceChain"},"audit":{"$ref":"https://quantum.local/schemas/metric-result-common.schema.json#/$defs/recalculationAudit"},"reproduction_hash":{"$ref":"https://quantum.local/schemas/metric-result-common.schema.json#/$defs/hash"},"content_hash":{"$ref":"https://quantum.local/schemas/metric-result-common.schema.json#/$defs/hash"}},"allOf":[{"if":{"properties":{"mode":{"const":"ACTUAL"}},"required":["mode"]},"then":{"properties":{"scenario_id