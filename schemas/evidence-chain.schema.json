{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantum.local/schemas/evidence-chain.schema.json",
  "title": "Quantum Evidence Chain v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_chain_id", "version", "content_hash", "metric_result_id",
    "metric_result_hash", "metric_definition_ref", "calculation_profile_ref",
    "rounding_policy_ref", "source_authority_ref", "source_files", "source_records",
    "events", "transformations", "links", "input_fingerprint", "replay_key",
    "actor", "created_at"
  ],
  "properties": {
    "evidence_chain_id": {"type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.:-]{0,127}$"},
    "version": {"type": "integer", "minimum": 1},
    "content_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "metric_result_id": {"type": "string", "minLength": 1},
    "metric_result_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "metric_definition_ref": {"$ref": "#/$defs/versionedRef"},
    "calculation_profile_ref": {"$ref": "#/$defs/versionedRef"},
    "rounding_policy_ref": {"$ref": "#/$defs/versionedRef"},
    "source_authority_ref": {"$ref": "#/$defs/versionedRef"},
    "source_files": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"$ref": "#/$defs/sourceFile"}
    },
    "source_records": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"$ref": "#/$defs/sourceRecord"}
    },
    "events": {
      "type": "array", "uniqueItems": true,
      "items": {"$ref": "#/$defs/event"}
    },
    "transformations": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"$ref": "#/$defs/transformation"}
    },
    "links": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"$ref": "#/$defs/link"}
    },
    "input_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "replay_key": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "versionedRef": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "version", "content_hash"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "integer", "minimum": 1},
        "content_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "sourceFile": {
      "type": "object", "additionalProperties": false,
      "required": ["source_file_id", "sha256", "size_bytes", "media_type", "ingested_at", "storage_key"],
      "properties": {
        "source_file_id": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "size_bytes": {"type": "integer", "minimum": 0},
        "media_type": {"type": "string", "minLength": 1},
        "ingested_at": {"type": "string", "format": "date-time"},
        "storage_key": {"type": "string", "minLength": 1}
      }
    },
    "sourceRecord": {
      "type": "object", "additionalProperties": false,
      "required": ["source_record_id", "import_batch_id", "source_row_key", "raw_row_hash", "source_file_sha256"],
      "properties": {
        "source_record_id": {"type": "string", "minLength": 1},
        "import_batch_id": {"type": "string", "minLength": 1},
        "source_row_key": {"type": "string", "minLength": 1},
        "raw_row_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "source_file_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "event": {
      "type": "object", "additionalProperties": false,
      "required": ["event_id", "schema_version", "revision", "semantic_payload_hash", "source_record_id", "source_file_sha256"],
      "properties": {
        "event_id": {"type": "string", "minLength": 1},
        "schema_version": {"type": "string", "minLength": 1},
        "revision": {"type": "integer", "minimum": 1},
        "semantic_payload_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "source_record_id": {"type": "string", "minLength": 1},
        "source_file_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "transformation": {
      "type": "object", "additionalProperties": false,
      "required": ["transformation_id", "version", "content_hash", "input_hash", "output_hash"],
      "properties": {
        "transformation_id": {"type": "string", "minLength": 1},
        "version": {"type": "integer", "minimum": 1},
        "content_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "input_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "output_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "link": {
      "type": "object", "additionalProperties": false,
      "required": ["from_kind", "from_id", "to_kind", "to_id", "relation"],
      "properties": {
        "from_kind": {"type": "string", "enum": ["METRIC_RESULT", "METRIC_DEFINITION", "CALCULATION_PROFILE", "ROUNDING_POLICY", "SOURCE_AUTHORITY", "EVENT", "TRANSFORMATION", "SOURCE_RECORD", "SOURCE_FILE"]},
        "from_id": {"type": "string", "minLength": 1},
        "to_kind": {"type": "string", "enum": ["METRIC_DEFINITION", "CALCULATION_PROFILE", "ROUNDING_POLICY", "SOURCE_AUTHORITY", "EVENT", "TRANSFORMATION", "SOURCE_RECORD", "SOURCE_FILE"]},
        "to_id": {"type": "string", "minLength": 1},
        "relation": {"type": "string", "enum": ["DEFINED_BY", "CALCULATED_WITH", "ROUNDED_WITH", "AUTHORIZED_BY", "DERIVED_FROM", "TRANSFORMED_BY", "NORMALIZED_FROM", "INGESTED_FROM"]}
      }
    }
  }
}
