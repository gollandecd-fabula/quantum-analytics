{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantum.local/schemas/financial-kernel-result.schema.json",
  "title": "Quantum Financial Kernel Preview Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "calculation_id", "organization_id", "mode",
    "scenario_id", "profile_ref", "rounding_policy_ref", "publication_state",
    "results", "limitations", "calculated_at", "input_hash", "result_hash"
  ],
  "properties": {
    "schema_version": {"const": "quantum-financial-kernel-result-v1"},
    "calculation_id": {"type": "string", "minLength": 1},
    "organization_id": {"type": "string", "minLength": 1},
    "mode": {"type": "string", "enum": ["ACTUAL", "SCENARIO"]},
    "scenario_id": {"type": ["string", "null"], "minLength": 1},
    "profile_ref": {"$ref": "#/$defs/versionedRef"},
    "rounding_policy_ref": {"$ref": "#/$defs/versionedRef"},
    "publication_state": {"const": "PREVIEW_ONLY"},
    "results": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "net_sold_units", "product_cost_amount", "other_expense_amount",
        "tax_amount", "net_marketplace_income_amount", "net_profit_amount",
        "profit_per_sold_unit", "profitability_of_costs"
      ],
      "properties": {
        "net_sold_units": {"$ref": "#/$defs/metricResult"},
        "product_cost_amount": {"$ref": "#/$defs/metricResult"},
        "other_expense_amount": {"$ref": "#/$defs/metricResult"},
        "tax_amount": {"$ref": "#/$defs/metricResult"},
        "net_marketplace_income_amount": {"$ref": "#/$defs/metricResult"},
        "net_profit_amount": {"$ref": "#/$defs/metricResult"},
        "profit_per_sold_unit": {"$ref": "#/$defs/metricResult"},
        "profitability_of_costs": {"$ref": "#/$defs/metricResult"}
      }
    },
    "limitations": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "calculated_at": {"type": "string", "format": "date-time"},
    "input_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "result_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "allOf": [
    {
      "if": {"properties": {"mode": {"const": "ACTUAL"}}, "required": ["mode"]},
      "then": {"properties": {"scenario_id": {"type": "null"}}},
      "else": {"properties": {"scenario_id": {"type": "string", "minLength": 1}}}
    }
  ],
  "$defs": {
    "versionedRef": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "version", "content_hash"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "integer", "minimum": 1},
        "content_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "rounding": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["policy_ref", "application_point", "resolved_mode", "resolved_scale"],
      "properties": {
        "policy_ref": {"$ref": "#/$defs/versionedRef"},
        "application_point": {"type": "string", "enum": ["RULE_INPUT_NORMALIZATION", "RULE_COMPONENT_RESULT", "METRIC_FINAL_ACCOUNTING"]},
        "resolved_mode": {"type": "string", "enum": ["HALF_EVEN", "HALF_UP", "DOWN", "UP", "FLOOR", "CEILING"]},
        "resolved_scale": {"type": "integer", "minimum": 0, "maximum": 28}
      }
    },
    "metricResult": {
      "type": "object", "additionalProperties": false,
      "required": [
        "state", "value", "value_type", "unit", "currency", "reason_code",
        "source_ids", "accounting_view", "expense_boundary", "rounding"
      ],
      "properties": {
        "state": {"type": "string", "enum": ["VALID", "EMPTY", "BLOCKED", "UNAVAILABLE", "CONFLICT"]},
        "value": {"type": ["string", "integer", "boolean", "null"]},
        "value_type": {"type": "string", "enum": ["MONEY", "DECIMAL", "RATE", "INTEGER", "BOOLEAN"]},
        "unit": {"type": "string", "minLength": 1},
        "currency": {"type": ["string", "null"], "pattern": "^[A-Z]{3}$"},
        "reason_code": {"type": ["string", "null"], "minLength": 1},
        "source_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "accounting_view": {"type": "string", "enum": ["OPERATIONAL", "SETTLEMENT", "TAX_RECOGNITION"]},
        "expense_boundary": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "rounding": {"$ref": "#/$defs/rounding"}
      },
      "allOf": [
        {
          "if": {"properties": {"state": {"const": "VALID"}}, "required": ["state"]},
          "then": {"properties": {"reason_code": {"type": "null"}, "value": {"not": {"type": "null"}}}},
          "else": {"properties": {"reason_code": {"type": "string", "minLength": 1}, "value": {"type": "null"}}}
        }
      ]
    }
  }
}
