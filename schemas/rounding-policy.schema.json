{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantum.local/schemas/rounding-policy.schema.json",
  "title": "Quantum Rounding Policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_id", "version", "content_hash", "status", "calculation_mode",
    "calculation_scale", "money_scale", "rate_scale", "presentation_mode",
    "presentation_scale", "currency_presentation_scales", "application_points",
    "max_input_precision", "max_input_scale", "actor", "created_at",
    "source", "change_reason", "approval_reference", "supersedes"
  ],
  "properties": {
    "policy_id": {"type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.:-]{0,127}$"},
    "version": {"type": "integer", "minimum": 1},
    "content_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "status": {"type": "string", "enum": ["DRAFT", "SHADOW", "PILOT", "ACTIVE", "SUSPENDED", "RETIRED"]},
    "calculation_mode": {"$ref": "#/$defs/mode"},
    "calculation_scale": {"type": "integer", "minimum": 0, "maximum": 28},
    "money_scale": {"type": "integer", "minimum": 0, "maximum": 28},
    "rate_scale": {"type": "integer", "minimum": 0, "maximum": 28},
    "presentation_mode": {"$ref": "#/$defs/mode"},
    "presentation_scale": {"type": "integer", "minimum": 0, "maximum": 28},
    "currency_presentation_scales": {
      "type": "object",
      "propertyNames": {"pattern": "^[A-Z]{3}$"},
      "additionalProperties": {"type": "integer", "minimum": 0, "maximum": 28}
    },
    "application_points": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "RULE_INPUT_NORMALIZATION", "RULE_COMPONENT_RESULT",
          "METRIC_FINAL_ACCOUNTING", "REPORT_PRESENTATION", "EXPORT_PRESENTATION"
        ]
      }
    },
    "max_input_precision": {"type": "integer", "minimum": 1, "maximum": 1000},
    "max_input_scale": {"type": "integer", "minimum": 0, "maximum": 1000},
    "actor": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "source": {"type": "string", "minLength": 1},
    "change_reason": {"type": "string", "minLength": 1},
    "approval_reference": {"type": ["string", "null"], "minLength": 1},
    "supersedes": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["policy_id", "version"],
          "properties": {
            "policy_id": {"type": "string", "minLength": 1},
            "version": {"type": "integer", "minimum": 1}
          }
        },
        {"type": "null"}
      ]
    }
  },
  "$defs": {
    "mode": {
      "type": "string",
      "enum": ["HALF_EVEN", "HALF_UP", "DOWN", "UP", "FLOOR", "CEILING"]
    }
  }
}
